generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
  ABANDONED
}

enum PredictionStatus {
  PENDING
  SCORED
  VOID
}

enum PointReason {
  EXACT_SCORE
  CORRECT_OUTCOME
  INCORRECT
  MANUAL_ADJUSTMENT
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  isAdmin      Boolean            @default(false)
  totalPoints  Int                @default(0)
  predictions  Prediction[]
  transactions PointTransaction[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([totalPoints])
}

model Competition {
  id         String   @id @default(cuid())
  providerId Int
  name       String
  country    String?
  logoUrl    String?
  season     Int
  isActive   Boolean  @default(true)
  matches    Match[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([providerId, season])
}

model Team {
  id          String   @id @default(cuid())
  providerId  Int      @unique
  name        String
  shortName   String?
  logoUrl     String?
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Match {
  id            String       @id @default(cuid())
  providerId    Int          @unique
  competitionId String
  homeTeamId    String
  awayTeamId    String
  startsAt      DateTime
  status        MatchStatus  @default(SCHEDULED)
  homeScore     Int?
  awayScore     Int?
  finishedAt    DateTime?
  lastSyncedAt  DateTime?
  competition   Competition  @relation(fields: [competitionId], references: [id])
  homeTeam      Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions   Prediction[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([startsAt])
  @@index([competitionId, startsAt])
  @@index([status, startsAt])
}

model Prediction {
  id           String            @id @default(cuid())
  userId       String
  matchId      String
  homeScore    Int
  awayScore    Int
  points       Int               @default(0)
  status       PredictionStatus  @default(PENDING)
  calculatedAt DateTime?
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  match        Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  transaction  PointTransaction?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([userId, matchId])
  @@index([matchId, status])
}

model PointTransaction {
  id           String      @id @default(cuid())
  userId       String
  predictionId String?     @unique
  points       Int
  reason       PointReason
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction   Prediction? @relation(fields: [predictionId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@index([userId, createdAt])
}

model SyncRun {
  id          String   @id @default(cuid())
  source      String
  competition String?
  status      String
  requests    Int      @default(0)
  synced      Int      @default(0)
  skipped     Int      @default(0)
  scored      Int      @default(0)
  failures    Json
  startedAt   DateTime @default(now())
  finishedAt  DateTime?

  @@index([startedAt])
  @@index([source, startedAt])
}
